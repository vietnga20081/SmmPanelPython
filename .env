APP_NAME=SMM Panel
APP_ENV=production
DEBUG=false

DATABASE_PATH=./data/smm_panel.db

SECRET_KEY=change-this-to-a-random-64-char-string
SESSION_COOKIE_NAME=smm_session
SESSION_MAX_AGE_SECONDS=86400
REMEMBER_COOKIE_NAME=smm_remember
REMEMBER_MAX_AGE_SECONDS=2592000

JWT_SECRET_KEY=change-this-to-another-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

CSRF_HEADER_NAME=X-CSRF-Token
CSRF_FIELD_NAME=csrf_token

LOG_DIR=./logs
LOG_LEVEL=INFO
